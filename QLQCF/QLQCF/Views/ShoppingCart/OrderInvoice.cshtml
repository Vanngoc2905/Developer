@model QLQCF.Models.Order

@{
    ViewData["Title"] = "Hóa đơn mua hàng";
    var banId = Context.Session.GetInt32("BanId");
    var tenBan = Context.Session.GetString("TenBan");
}

<h2 class="text-center mb-4">🧾 Hóa đơn mua hàng</h2>
<hr />

<table class="table">
    <tr>
        <th>Mã đơn hàng:</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Khách hàng:</th>
        <td>@Model.CustomerName</td>
    </tr>
    <tr>
        <th>Ngày đặt:</th>
        <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
    </tr>
    <tr>
        <th>Địa chỉ giao hàng:</th>
        <td>@Model.ShippingAddress</td>
    </tr>
    @if (ViewBag.BanId != null)
    {
        <tr>
            <th>Bàn:</th>
            <td>@ViewBag.BanId - @ViewBag.TenBan</td>
        </tr>
    }

</table>

<h4 class="mb-3">📦 Chi tiết đơn hàng</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Sản phẩm</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OrderDetails)
        {
            <tr>
                <td>@item.Product?.Name</td>
                <td>@item.Quantity</td>
                <td>@item.Price.ToString("N0") VNĐ</td>
                <td>@(item.Price * item.Quantity).ToString("N0") VNĐ</td>
            </tr>
        }
    </tbody>
</table>

<h4 class="text-right">💰 Tổng tiền: <strong>@Model.TotalPrice.ToString("N0") VNĐ</strong></h4>

<div class="mt-4">
    <a href="/" class="btn btn-secondary">🏠 Về trang chủ</a>
</div>
