@* Views/Categories/Index.cshtml *@
@model IEnumerable<QLQCF.Models.Category>

<div class="container mt-4">
    <h2 class="text-center mb-4">✨ Danh Mục Sản Phẩm ✨</h2>

    @* Thông báo nếu có *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between mb-3">
        <a asp-action="Add" class="btn btn-success">
            <i class="fas fa-plus-circle"></i> Thêm Danh Mục
        </a>
    </div>

    <table class="table table-bordered table-hover text-center">
        <thead class="table-info">
            <tr>
                <th>ID</th>
                <th>Tên Danh Mục</th>
             
                <th>Chức Năng</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Id</td>
                    <td>@category.Name</td>
          
                    <td>
                        <a asp-action="Update" asp-route-id="@category.Id" class="btn btn-warning btn-sm">
                            <i class="fas fa-edit"></i> Sửa
                        </a>

                        <form asp-action="DeleteConfirmed" asp-route-id="@category.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Bạn có chắc muốn xóa danh mục này không?');">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash-alt"></i> Xóa
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* Thêm link Font Awesome để có icon đẹp *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<script src="~/js/script.js"></script>