@using Microsoft.AspNetCore.Http
@using Newtonsoft.Json
@inject IHttpContextAccessor HttpContextAccessor


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Coffee Shop</title>

    <!-- FontAwesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <!-- Bootstrap CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
 

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    @{
        // Lấy giỏ hàng từ session
        var cartJson = HttpContextAccessor.HttpContext.Session.GetString("Cart");
        var cart = string.IsNullOrEmpty(cartJson) ? new ShoppingCart() : JsonConvert.DeserializeObject<ShoppingCart>(cartJson);
        var cartItemCount = cart.Items?.Sum(i => i.Quantity) ?? 0;  // Tổng số lượng sản phẩm trong giỏ
    }


    <!-- Header -->
    <header class="header">

        <button onclick="document.getElementById('menu-btn').classList.toggle('active')" class="btn btn-outline-dark">
            <i class="bi bi-list"></i> Menu
        </button>

        <div id="menu-btn">
            <a asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-door"></i> Trang Chủ
            </a>
            <a asp-area="" asp-controller="Ban" asp-action="Index">
                <i class="bi bi-table"></i> Bàn
            </a>

            <a asp-controller="Product" asp-action="CategoryDetail" asp-route-category="Đồ Uống">
                <i class="bi bi-cup-straw"></i> Nước Uống
            </a>

            <a asp-controller="Product" asp-action="CategoryDetail" asp-route-category="Đồ Ăn">
                <i class="bi bi-bag-fill"></i> Ăn Vặt
            </a>
            <a asp-controller="ShoppingCart" asp-action="InvoiceHistoryList" class="nav-link">
                <i class="fas fa-history"></i> Lịch sử mua hàng
            </a>

    



            @if (User.IsInRole(SD.Role_Admin))
            {
                <a asp-area="" asp-controller="Orders" asp-action="Index">
                    <i class="bi bi-bar-chart-line"></i> Thống Kê
                </a>

                <a asp-area="" asp-controller="Product" asp-action="Index">
                    <i class="bi bi-box-seam"></i> Sản Phẩm
                </a>

                <a asp-area="" asp-controller="Role" asp-action="Index">
                    <i class="bi bi-people"></i> Cấp Quyền
                </a>

                <a asp-controller="Inventory" asp-action="Index">
                    <i class="bi bi-box-seam"></i> Kho hàng

                </a>
            }

            @if (User.Identity.IsAuthenticated)
            {
                <a id="manage" class="nav-link text-dark d-flex align-items-center" asp-area="Identity" asp-page="/Account/Manage/Index" title="Quản lý tài khoản">
                    <i class="bi bi-person-circle" style="font-size: 1.5rem; margin-right: 5px;"></i> Tài khoản
                </a>


                <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button id="logout" type="submit" class="nav-link btn btn-link text-dark border-0 px-md-2 py-md-1">
                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                    </button>
                </form>

            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login">
                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                </a>

                <a asp-area="Identity" asp-page="/Account/Register">
                    <i class="bi bi-person-plus"></i> Đăng ký
                </a>
            }
        </div>

    

        <nav class="navbar">
            <a href="#" class="logo">
                <img src="~/images/images.jpg" alt="Coffee Shop Logo">
            </a>
            <h1> Cà Phê Tình Cờ </h1>

           
        </nav>
     
        <div class="icons">
            <div class="fas fa-search" id="search-btn"></div>
            <div class="fas fa-shopping-cart" id="cart-btn"></div>
    
        </div>

        <div class="cart-items-container">
           <div>
               <h1>Giỏ Hàng Của Bạn</h1>
           </div>
            <div class="cart-item">
                <div class="cart-details">
                    <div class="list-group">
                        <div class="list-group-item d-flex justify-content-between fw-bold bg-light">
                            <span>Sản Phẩm</span>
                            <span class="text-center" style="width: 120px;">Số Lượng</span>
                            <span class="text-end" style="width: 100px;">Đơn Giá</span>
                            <span class="text-end" style="width: 100px;">Tổng Cộng</span>
                            <span style="width: 80px;"></span>
                        </div>

                        @foreach (var item in cart.Items)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center cart-item-row" data-product-id="@item.ProductId">
                                <div class="d-flex align-items-center" style="flex-grow: 1;">
                                    <img src="@item.ImageUrl" alt="@item.Name" class="cart-item-image me-2" style="width: 50px; height: 50px; object-fit: cover;" />
                                    <span class="cart-item-name">@item.Name</span>
                                </div>

                                <div class="quantity-adjust d-flex align-items-center justify-content-center" style="width: 120px;">
                                    <button class="btn btn-sm btn-outline-secondary decrease">-</button>
                                    <input type="text" class="quantity-display mx-2 text-center" value="@item.Quantity" readonly style="width: 40px;" />
                                    <button class="btn btn-sm btn-outline-secondary increase">+</button>
                                </div>

                                <span class="cart-item-price text-danger fw-bold text-end" style="width: 100px;">@item.Price.ToString("N0") VNĐ</span>

                                <span class="cart-item-total fw-bold text-end" style="width: 100px;">@(((int)(item.Price * item.Quantity)).ToString("N0")) VNĐ</span>
                                <button class="btn btn-danger btn-sm remove-from-cart" data-product-id="@item.ProductId" style="width: 100px;">Xóa</button>
                            </div>
                        }
                    </div>

                    <div class="cart-total d-flex justify-content-end mt-3">
                        <span class="me-2">Tổng Tiền:</span>
                        <span id="total-price" style="font-weight: bold; color: red;">@(cart.Items.Sum(i => i.Price * i.Quantity).ToString("N0")) VNĐ</span>
                    </div>
    
                    <div class="d-flex justify-content-end mt-3">
                        <a asp-controller="ShoppingCart" asp-action="Checkout" class="btn btn-danger btn-lg shadow-lg hover:shadow-2xl transition-all">Thanh Toán</a>
                    </div>
                </div>
                @if (cartItemCount == 0)
                {
                    <div class="alert alert-warning text-center mt-3" role="alert">
                        Giỏ hàng của bạn hiện tại chưa có sản phẩm nào!
                    </div>
                }
                @section Scripts {
                    <script src="~/js/script.js"></script>
                    
                }



            </div>

        </div>
     
        <form asp-controller="Home" asp-action="Search" method="get" class="search-form">
            <input class="form-control me-2" type="text" name="searchTerm" placeholder="Tìm kiếm sản phẩm..." aria-label="Search" required>
            <button class="btn btn-outline-light" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </form>

    </header>

    <!-- Main Content -->
    <main class="container my-5">
        @RenderBody()
    </main>
    <script>
                document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".increase").forEach(button => {
                button.addEventListener("click", function () {
                    let row = this.closest(".cart-item-row");
                    if (!row) return;

                    let productId = row.getAttribute("data-product-id");
                    let quantityInput = row.querySelector(".quantity-display");
                    let currentQuantity = parseInt(quantityInput.value);

                    fetch(`/ShoppingCart/CheckIngredientAvailability?productId=${productId}&quantity=${currentQuantity + 1}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                // Nếu đủ nguyên liệu thì tăng số lượng
                                fetch(`/ShoppingCart/UpdateQuantity`, {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({
                                        productId: productId,
                                        quantity: currentQuantity + 1
                                    })
                                }).then(response => {
                                    if (response.ok) {
                                        quantityInput.value = currentQuantity + 1;
                                        updateTotalPrice();
                                    }
                                });
                            } else {
                                // Nếu không đủ: cảnh báo + đặt về 1
                                Swal.fire({
                                    icon: 'warning',
                                    title: 'Không thể tăng số lượng',
                                    text: data.message,
                                    confirmButtonText: 'OK',
                                }).then(() => {
                                    // Set lại về 1
                                    quantityInput.value = 1;

                                    fetch(`/ShoppingCart/UpdateQuantity`, {
                                        method: 'POST',
                                        headers: { 'Content-Type': 'application/json' },
                                        body: JSON.stringify({
                                            productId: productId,
                                            quantity: 1
                                        })
                                    }).then(() => {
                                        updateTotalPrice();
                                    });
                                });
                            }
                        })
                        .catch(err => {
                            console.error("Lỗi kiểm tra nguyên liệu:", err);
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi hệ thống',
                                text: 'Không thể kiểm tra nguyên liệu!',
                            });
                        });
                });
            });
        function updateTotalPrice() {
            let total = 0;

            // Duyệt qua tất cả các sản phẩm trong giỏ
            document.querySelectorAll(".cart-item-row").forEach(row => {
                const quantityInput = row.querySelector(".quantity-display");
                const priceText = row.querySelector(".cart-item-price")?.textContent || '0';  // Đảm bảo có giá trị mặc định

                const quantity = parseInt(quantityInput.value) || 0; // Nếu không có giá trị, mặc định là 0
                const price = parseInt(priceText.replace(/[^\d]/g, '')) || 0; // Làm sạch giá trị và chuyển sang số

                // Tính tổng cho sản phẩm này
                const itemTotal = quantity * price;

                // Cập nhật tổng cho mỗi sản phẩm
                row.querySelector(".cart-item-total").textContent = itemTotal.toLocaleString() + " VNĐ";

                // Cộng vào tổng tiền giỏ hàng
                total += itemTotal;
            });

            // Cập nhật tổng tiền cuối cùng
            const totalPriceElement = document.getElementById("total-price");
            if (totalPriceElement) {
                totalPriceElement.textContent = total.toLocaleString() + " VNĐ";
            }
        }

        });


    </script>

 
    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-3" style="position: fixed; bottom: 0; left: 0; width: 100%; z-index: 1000;">
        <p>&copy; 2024 Coffee Shop. All Rights Reserved.</p>
    </footer>


    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


    <!-- Custom JS -->
    <script src="~/js/script.js" asp-append-version="true"></script>


    <!-- Fix lỗi Scripts Section -->
    @RenderSection("Scripts", required: false)



</body>
</html>