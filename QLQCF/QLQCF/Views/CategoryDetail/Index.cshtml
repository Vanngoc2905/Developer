<!-- Views/CategoryDetail/Index.cshtml -->
@model IEnumerable<QLQCF.Models.CategoryDetail>

<h2>Danh Sách Chi Tiết Danh Mục</h2>
<a asp-action="Add" class="btn btn-primary mb-3">Thêm Chi Tiết Danh Mục</a>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tên Chi Tiết</th>
            <th>Danh Mục</th>
            <th>Hành Động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.DetailName</td>
                <td>@item.Category.Name</td>
                <td>
                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<script src="~/js/script.js"></script>