@model QLQCF.Models.Order

@{
    ViewData["Title"] = "Chi tiết hóa đơn";
}

<h2 class="text-center mb-4">🧾 Hóa đơn mua hàng</h2>
<hr />

<table class="table table-striped">
    <tr>
        <th>Mã đơn hàng:</th>
        <td>@Model.Id</td>
    </tr>
    <tr>
        <th>Khách hàng:</th>
        <td>@Model.CustomerName</td>
    </tr>
    <tr>
        <th>Ngày đặt:</th>
        <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
    </tr>
    <tr>
        <th>Địa chỉ giao hàng:</th>
        <td>@Model.ShippingAddress</td>
    </tr>
    @if (Model.BanId != null && Model.Ban != null)
    {
        <tr>
            <th>Bàn:</th>
            <td>@Model.BanId - @Model.Ban.Name</td>
        </tr>
    }
    else
    {
        <tr>
            <th>Hình thức:</th>
            <td>Mang đi</td>
        </tr>
    }
</table>

<h4 class="mb-3">📦 Chi tiết đơn hàng</h4>

<table class="table table-bordered">
    <thead class="table-light">
        <tr>
            <th>Sản phẩm</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OrderDetails)
        {
            <tr>
                <td>@item.Product?.Name</td>
                <td>@item.Quantity</td>
                <td>@item.Price.ToString("N0") VNĐ</td>
                <td>@(item.Price * item.Quantity).ToString("N0") VNĐ</td>
            </tr>
        }
    </tbody>
</table>

<h4 class="text-end mt-4">💰 Tổng tiền: <strong>@Model.TotalPrice.ToString("N0") VNĐ</strong></h4>

<div class="mt-4">
    <a href="/Orders/History" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Quay lại danh sách
    </a>

</div>
