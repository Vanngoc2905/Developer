@model QLQCF.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Thêm Sản Phẩm";
}

<h2>Thêm Sản Phẩm</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-action="Add" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" class="form-control" required min="0" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoryDetailId">Danh Mục</label>
        <select asp-for="CategoryDetailId" asp-items="ViewBag.CategoryDetails" class="form-control" required>
            <option value="">-- Chọn danh mục --</option>
        </select>
        <span asp-validation-for="CategoryDetailId" class="text-danger"></span>
    </div>


    <div class="form-group">
        <label for="image">Hình Ảnh</label>
        <input type="file" name="image" class="form-control" accept="image/*" required />
    </div>

    <button type="submit" class="btn btn-success">
        <i class="fas fa-plus"></i> Thêm Sản Phẩm
    </button>
</form>